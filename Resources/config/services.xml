<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <!-- Core Service -->
        <service id="Four\MediaIntegrityChecker\Service\MediaIntegrityChecker">
            <argument type="service" id="media.repository"/>
            <argument type="service" id="shopware.filesystem.public"/>
            <argument type="service" id="monolog.logger.four_media_integrity"/>
        </service>

        <!-- CLI Command -->
        <service id="Four\MediaIntegrityChecker\Command\MediaIntegrityCheckCommand">
            <argument type="service" id="Four\MediaIntegrityChecker\Service\MediaIntegrityChecker"/>
            <tag name="console.command"/>
        </service>

        <!-- Scheduled Task -->
        <service id="Four\MediaIntegrityChecker\ScheduledTask\MediaIntegrityCheckTask">
            <tag name="shopware.scheduled.task"/>
        </service>

        <!-- Scheduled Task Handler -->
        <service id="Four\MediaIntegrityChecker\ScheduledTask\MediaIntegrityCheckTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="monolog.logger.four_media_integrity"/>
            <argument type="service" id="Four\MediaIntegrityChecker\Service\MediaIntegrityChecker"/>
            <tag name="messenger.message_handler"/>
        </service>
    </services>
</container>
